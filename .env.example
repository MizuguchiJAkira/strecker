# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=basal
DB_USER=basal
DB_PASSWORD=basal_dev

# Strecker
STRECKER_UPLOAD_DIR=./uploads
STRECKER_MAX_BATCH_SIZE=500

# Classification model
MODEL_PATH=./models/species_classifier.pt
MEGADETECTOR_PATH=./models/megadetector_v5.pt

# API keys (populate in .env, never commit)
OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Flask
FLASK_SECRET_KEY=change-me-in-production  # REQUIRED for production — use: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_DEBUG=1  # Set to 0 in production
